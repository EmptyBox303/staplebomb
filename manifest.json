{
  "manifest_version": 3,
  "name": "Pin Bomb",
  "version": "1.0",
  "description": "Track tab usage with pins. Blow them up with bombs.",
  "permissions": ["activeTab","tabs","scripting","nativeMessaging","storage"],
  "action": {
    "default_icon": "pinbomb48.png",
    "default_popup" : "popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "./src/utils.js",
        "./src/content.js"
      ],

      "css" : 
      ["style/window_stopwatch.css"]
    }
  ]
}



